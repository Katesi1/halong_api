generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(uuid())
  name         String
  phone        String    @unique
  email        String?   @unique
  password     String
  role         Int       @default(1) // 0=ADMIN, 1=STAFF, 2=CUSTOMER
  gender       Int?      // 0=MALE, 1=FEMALE, 2=OTHER
  dateOfBirth  DateTime?
  isActive     Boolean   @default(true)
  refreshToken String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  properties       Property[]
  notifications    Notification[]
  saleBookings     Booking[]  @relation("SaleBookings")
  customerBookings Booking[]  @relation("CustomerBookings")

  @@map("users")
}

model Property {
  id                 String   @id @default(uuid())
  ownerId            String
  name               String
  type               Int      @default(1) // 0=VILLA, 1=HOMESTAY, 2=APARTMENT, 3=HOTEL
  code               String   @unique
  isActive           Boolean  @default(true)

  // Location
  address            String?
  latitude           Float?
  longitude          Float?
  mapLink            String?

  // Specs
  bedrooms           Int      @default(1)
  bathrooms          Int      @default(1)
  standardGuests     Int      @default(2)
  maxGuests          Int      @default(2)

  // Pricing
  weekdayPrice       Float?
  weekendPrice       Float?
  holidayPrice       Float?
  adultSurcharge     Float?
  childSurcharge     Float?

  // Content
  amenities          String[] @default([])
  cancellationPolicy Int      @default(0) // 0=FLEXIBLE, 1=MODERATE, 2=STRICT
  rules              String?
  services           String[] @default([])
  description        String?

  // Check in/out
  checkInTime        String?  @default("14:00")
  checkOutTime       String?  @default("12:00")

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  owner         User            @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  images        PropertyImage[]
  bookings      Booking[]
  calendarLocks CalendarLock[]

  @@map("properties")
}

model PropertyImage {
  id         String   @id @default(uuid())
  propertyId String
  imageUrl   String
  publicId   String
  isCover    Boolean  @default(false)
  order      Int      @default(0)
  createdAt  DateTime @default(now())

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@map("property_images")
}

model Booking {
  id             String    @id @default(uuid())
  propertyId     String
  saleId         String?
  customerId     String?
  customerName   String?
  customerPhone  String?
  checkinDate    DateTime
  checkoutDate   DateTime
  status         Int       @default(0) // 0=HOLD, 1=CONFIRMED, 2=CANCELLED, 3=COMPLETED
  holdExpireAt   DateTime?
  depositAmount  Float?
  guestCount     Int       @default(2)
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  property Property @relation(fields: [propertyId], references: [id])
  sale     User?    @relation("SaleBookings", fields: [saleId], references: [id])
  customer User?    @relation("CustomerBookings", fields: [customerId], references: [id])

  @@map("bookings")
}

model CalendarLock {
  id         String   @id @default(uuid())
  propertyId String
  date       DateTime
  status     Int      @default(0) // 0=LOCKED, 1=BOOKED
  createdAt  DateTime @default(now())

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@map("calendar_locks")
}

model PartnerKey {
  id          String   @id @default(uuid())
  partnerName String
  apiKey      String   @unique
  isActive    Boolean  @default(true)
  rateLimit   Int      @default(100)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("partner_keys")
}

model Notification {
  id         String   @id @default(uuid())
  userId     String
  title      String
  subtitle   String?
  type       Int      @default(2) // 0=BOOKING, 1=PAYMENT, 2=SYSTEM
  isRead     Boolean  @default(false)
  targetId   String?
  targetType String?
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@map("notifications")
}
