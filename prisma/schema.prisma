generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  STAFF
  CUSTOMER
}

enum BookingStatus {
  HOLD
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum RoomType {
  VILLA
  HOMESTAY
  APARTMENT
  HOTEL
}

enum CancellationPolicy {
  FLEXIBLE
  MODERATE
  STRICT
}

enum NotificationType {
  BOOKING
  PAYMENT
  SYSTEM
}

model User {
  id           String    @id @default(uuid())
  name         String
  phone        String    @unique
  email        String?   @unique
  password     String
  role         Role      @default(STAFF)
  isActive     Boolean   @default(true)
  gender       String?
  dateOfBirth  DateTime?
  refreshToken String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  properties       Property[]
  notifications    Notification[]
  saleBookings     Booking[]  @relation("SaleBookings")
  customerBookings Booking[]  @relation("CustomerBookings")

  @@map("users")
}

model Property {
  id        String   @id @default(uuid())
  ownerId   String
  name      String
  address   String
  latitude  Float?
  longitude Float?
  mapLink   String?
  rules     String?
  services  String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  owner User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  rooms Room[]

  @@map("properties")
}

model Room {
  id                 String              @id @default(uuid())
  propertyId         String
  name               String
  code               String              @unique
  type               RoomType?
  bedrooms           Int                 @default(1)
  bathrooms          Int                 @default(1)
  standardGuests     Int                 @default(2)
  maxGuests          Int                 @default(2)
  description        String?
  address            String?
  mapLink            String?
  amenities          String[]            @default([])
  cancellationPolicy CancellationPolicy?
  adultSurcharge     Float?
  childSurcharge     Float?
  isActive           Boolean             @default(true)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  property Property    @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  images   RoomImage[]
  price    RoomPrice?
  bookings Booking[]

  @@map("rooms")
}

model RoomImage {
  id         String   @id @default(uuid())
  roomId     String
  imageUrl   String
  publicId   String   // Cloudinary public_id để xoá ảnh
  isCover    Boolean  @default(false)
  order      Int      @default(0)
  createdAt  DateTime @default(now())

  room Room @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@map("room_images")
}

model RoomPrice {
  id             String   @id @default(uuid())
  roomId         String   @unique
  weekdayPrice   Float    @default(0)
  fridayPrice    Float    @default(0)
  saturdayPrice  Float    @default(0)
  holidayPrice   Float    @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  room Room @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@map("room_prices")
}

model Booking {
  id             String        @id @default(uuid())
  roomId         String
  saleId         String?
  customerId     String?
  checkinDate    DateTime
  checkoutDate   DateTime
  status         BookingStatus @default(HOLD)
  holdExpireAt   DateTime?
  customerName   String?
  customerPhone  String?
  depositAmount  Float?
  guestCount     Int           @default(2)
  notes          String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  room     Room  @relation(fields: [roomId], references: [id])
  sale     User? @relation("SaleBookings", fields: [saleId], references: [id])
  customer User? @relation("CustomerBookings", fields: [customerId], references: [id])

  @@map("bookings")
}

model PartnerKey {
  id          String   @id @default(uuid())
  partnerName String
  apiKey      String   @unique
  isActive    Boolean  @default(true)
  rateLimit   Int      @default(100)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("partner_keys")
}

model Notification {
  id         String           @id @default(uuid())
  userId     String
  title      String
  subtitle   String?
  type       NotificationType @default(SYSTEM)
  isRead     Boolean          @default(false)
  targetId   String?
  targetType String?
  createdAt  DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@map("notifications")
}
